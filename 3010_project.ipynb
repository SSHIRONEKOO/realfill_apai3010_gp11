import os
import sys
import subprocess
import ctypes

# 1. Manually find and load the library into the process memory
try:
    path_search = subprocess.check_output(['find', '/usr', '-name', 'libnvJitLink.so.13'], stderr=subprocess.STDOUT).decode().strip().split('\n')[0]
    if path_search:
        print(f"Manually loading: {path_search}")
        # Load the library globally so bitsandbytes can find it
        ctypes.CDLL(path_search, mode=ctypes.RTLD_GLOBAL)

        cuda_path = os.path.dirname(path_search)
        os.environ['LD_LIBRARY_PATH'] = f"{cuda_path}:/usr/lib64-nvidia:/usr/local/cuda/lib64:" + os.environ.get('LD_LIBRARY_PATH', '')
